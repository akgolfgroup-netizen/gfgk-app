# Neon Postgres connection string.
# Create a project at https://console.neon.tech, then copy the connection string.
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# Auth.js JWT signing secret. Generate with:
#   openssl rand -base64 32
AUTH_SECRET=

# Set only when running behind a proxy that strips the Host header.
# Vercel sets this automatically — leave commented for local dev.
# AUTH_TRUST_HOST=true
