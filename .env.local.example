# =========================================================================
# GFGK-app environment variables (lokal utvikling)
# Kopier denne fila til `.env.local` og fyll inn verdier.
# =========================================================================

# ----- KJERNE -----

# Neon Postgres connection string.
# Lag prosjekt på https://console.neon.tech, kopier connection string.
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# Auth.js JWT signing secret. Generer med:
#   openssl rand -base64 32
AUTH_SECRET=

# Sett kun når appen kjører bak en proxy som strikker Host-headeren.
# Vercel setter dette automatisk — la den være kommentert lokalt.
# AUTH_TRUST_HOST=true


# ----- E-POST (Resend) -----

# API-nøkkel fra https://resend.com/api-keys
# Hvis tom, hopper sendEmail() over uten å feile (logges til konsoll).
RESEND_API_KEY=

# Avsender-adresse. Default: "GFGK <onboarding@resend.dev>"
# I prod: bytt til "GFGK <noreply@gfgk.no>" når domenet er verifisert.
# RESEND_FROM="GFGK <noreply@gfgk.no>"


# ----- DEMO / DEV -----

# Aktiver /demo-ruten (live-demo som logger inn som demo-bruker).
# Sett til "true" kun i preview/dev. ALDRI true i prod.
ENABLE_DEMO=false


# ----- VERCEL BLOB (Sub-prosjekt A) -----

# Token fra Vercel-prosjektets Storage-tab.
# Trengs for avatar-opplasting og senere vedlegg.
BLOB_READ_WRITE_TOKEN=


# ----- AI GATEWAY (Sub-prosjekt D) -----

# Vercel AI Gateway API-nøkkel. Brukes til AI-utkast i inbox.
# Hent fra https://vercel.com/dashboard/ai/gateway
# AI_GATEWAY_API_KEY=


# ----- PUSH-VARSLER (Sub-prosjekt E) -----

# VAPID-nøkler for Web Push. Generer med:
#   npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:anders@gfgk.no
